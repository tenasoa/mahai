generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  prenom        String
  nom           String?
  role          Role    @default(ETUDIANT)
  credits       Int     @default(10)
  phone         String?
  phoneVerified Boolean @default(false)
  schoolLevel   String?
  emailVerified Boolean @default(false)

  subjects           Subject[]
  purchases          Purchase[]
  examAttempts       ExamenBlanc[]
  contributions      SubjectSubmission[]
  wishlist           Wishlist[]
  creditTransactions CreditTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ETUDIANT
  CONTRIBUTEUR
  PROFESSEUR
  VERIFICATEUR
  VALIDATEUR
  ADMIN
}

model Subject {
  id          String  @id @default(cuid())
  titre       String
  type        ExamenType
  matiere     String
  annee       String
  serie       String?
  description String?
  pages       Int
  credits     Int
  
  difficulte  Difficulte @default(MOYEN)
  langue      Langue     @default(FRANCAIS)
  format      Format     @default(PDF)
  badge       Badge      @default(AI)
  glyph       String     @default("∑")
  featured    Boolean    @default(false)
  
  rating       Float @default(0)
  reviewsCount Int   @default(0)

  hasCorrectionIa   Boolean @default(false)
  hasCorrectionProf Boolean @default(false)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  purchases     Purchase[]
  wishlistItems Wishlist[]

  createdAt DateTime @default(now())
}

enum ExamenType {
  BAC
  BEPC
  CEPE
}

enum Difficulte {
  FACILE
  MOYEN
  DIFFICILE
}

enum Langue {
  FRANCAIS
  MALGACHE
}

enum Format {
  PDF
  INTERACTIF
}

enum Badge {
  GOLD
  AI
  FREE
  INTER
}

model Purchase {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  subjectId     String?
  subject       Subject? @relation(fields: [subjectId], references: [id])
  creditsAmount Int
  amount        Float
  paymentMethod String?
  status        String   @default("PENDING")

  createdAt DateTime @default(now())
}

model ExamenBlanc {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  titre      String
  typeExamen String
  matiere    String
  annee      String

  dureeSecondes Int
  startedAt     DateTime?
  submittedAt   DateTime?

  score      Float?
  scoreMax   Float?
  percentile Float?

  status ExamenStatus @default(NOT_STARTED)

  createdAt DateTime @default(now())
}

enum ExamenStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  GRADED
}

model CreditTransaction {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id])
  amount        Int
  type          String // "PURCHASE" | "SPEND" | "REFUND" | "EARN"
  description   String?
  paymentMethod String? // "MVOLA" | "ORANGE" | "AIRTEL"
  transactionId String? // ID transaction Mobile Money
  status        String  @default("PENDING") // "PENDING" | "COMPLETED" | "FAILED"

  createdAt DateTime @default(now())
}

model SubjectSubmission {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  content Json

  status      SubmissionStatus @default(PENDING)
  reviewerId  String?
  validatedAt DateTime?

  createdAt DateTime @default(now())
}

enum SubmissionStatus {
  PENDING
  UNDER_REVIEW
  REJECTED
  VALIDATED
  PUBLISHED
}

model Wishlist {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, subjectId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
