# ============================================
# MAH.AI — Variables d'environnement
# ============================================
# Copier ce fichier vers .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans Git
# ============================================

# ── CLERK (Authentification) ──────────────────────────────────
# Obtenir sur https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── SUPABASE (Base de données) ────────────────────────────────
# Obtenir sur https://supabase.com
# Connection string avec password encodé (URL encode)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.xxx.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.xxx.supabase.co:5432/postgres"

# ── VERCEL BLOB (Storage) ─────────────────────────────────────
# Obtenir sur Vercel Dashboard > Storage > Blob > Connect
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── APP ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── NODE ──────────────────────────────────────────────────────
NODE_ENV=development
